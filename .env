# ============================================================
# ACTIZO CRM — Frontend environment (single file)
# Backend API base URL. Keep the /api suffix.
# Switch backends by commenting one line and uncommenting the
# other, then restart the dev server (npm run dev) or rebuild.
# Only ONE VITE_API_URL line should be active at a time.
# ============================================================

# Local backend (default for development):
# VITE_API_URL=http://localhost:5000/api

# Deployed backend on Render (uncomment this + comment the line above to use):
VITE_API_URL=https://actizo-backend.onrender.com/api
